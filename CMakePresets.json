{
    "version": 4,
    "configurePresets": [
        {
            "name": "default",
            "binaryDir": "${sourceDir}/build/dev",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "ALFRED_DISTRIBUTION": "OFF",
                "ALFRED_ASAN": "OFF",
                "ALFRED_ASAN_THREAD": "OFF"
            }
        },
        {
            "name": "conf-dev-nix",
            "inherits": "default"
        },
        {
            "name": "conf-dev-nix-asan",
            "inherits": "default",
            "cacheVariables": {
                "ALFRED_ASAN": "ON"
            }
        },
        {
            "name": "conf-dev-nix-asan-thread",
            "inherits": "default",
            "cacheVariables": {
                "ALFRED_ASAN": "ON",
                "ALFRED_ASAN_THREAD": "ON"
            }
        },
        {
            "name": "conf-dev-win",
            "inherits": "default"
        },
        {
            "name": "conf-dist-nix",
            "inherits": "default",
            "binaryDir": "${sourceDir}/build/dist",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "OFF",
                "ALFRED_DISTRIBUTION": "ON"
            }
        },
        {
            "name": "conf-dist-nix-rpm",
            "inherits": "conf-dist-nix",
            "cacheVariables": {
                "CPACK_GENERATOR": "RPM;TGZ"
            }
        },
        {
            "name": "conf-dist-nix-deb",
            "inherits": "conf-dist-nix",
            "cacheVariables": {
                "CPACK_GENERATOR": "DEB;TGZ"
            }
        },
        {
            "name": "conf-dist-win",
            "inherits": "default",
            "binaryDir": "${sourceDir}/build/dist",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "OFF",
                "ALFRED_DISTRIBUTION": "ON"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "build-dev-nix",
            "configurePreset": "conf-dev-nix",
            "jobs": 4
        },
        {
            "name": "build-dev-win",
            "configurePreset": "conf-dev-win",
            "jobs": 4,
            "configuration": "Debug"
        },
        {
            "name": "build-dist-nix",
            "configurePreset": "conf-dist-nix",
            "jobs": 8,
            "cleanFirst": true
        },
        {
            "name": "build-dist-win",
            "configurePreset": "conf-dist-win",
            "jobs": 8,
            "configuration": "Release",
            "cleanFirst": true
        }
    ]
}
